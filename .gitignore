# Prevent anything in the examples directory from being included.
examples/**

# Re-allow directories (only) so git can descend
!examples/**/

# Re-allow files that we want to maintain.
!examples/**/*.cc
!examples/**/*.cpp
!examples/**/*.css
!examples/**/*.emplex
!examples/**/*.h
!examples/**/*.hpp
!examples/**/*.html
